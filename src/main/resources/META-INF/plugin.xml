<idea-plugin>
  <id>com.github.claudecommit</id>
  <name>Claude Code Commit</name>
  <version>1.2.0</version>
  <vendor url="https://github.com/sxin0">sxin0</vendor>
  <description><![CDATA[
    Generates Git commit messages with the Claude CLI. Adds a button to the commit
    panel toolbar that sends the list of files checked for the commit to Claude,
    which inspects the diffs itself via read-only git commands and fills the
    generated message into the commit message field.<br>
    Configurable under <b>Settings &gt; Tools &gt; Claude Code Commit</b>:
    Claude CLI path, timeout, and a customizable prompt appended to the built-in one.
  ]]></description>
  <change-notes><![CDATA[
    <b>1.2.0</b> — Optional setting to auto-close the Terminal tool window when a
    project opens (independent of commit-message generation; requires the Terminal
    plugin). Kept in its own group on the settings page.

    <b>1.1.0</b> — Editor popup menu actions "复制 CC 引用" (copies a Claude Code
    reference, @path#Lstart-end, for the current file and selection) and
    "发送 CC 引用" (types the reference into the active terminal tab).

    <b>1.0.1</b> — Save API Key in plugin settings.

    <b>1.0.0</b> — Initial release: commit-panel button, Claude CLI integration,
    tag-based message extraction, customizable prompt.
  ]]></change-notes>
  <!-- Requires 2025.3.6 (build 253.33813.25) or newer: ReworkedTerminalSender links
       against the reworked-terminal frontend API (com.intellij.terminal.frontend.toolwindow
       / .view), which is absent on 2025.2 and earlier and fails the binary-compat check.
       jvm-target 21 also requires the JBR 21 runtime. -->
  <idea-version since-build="253.33813.25"/>
  <!-- Action text/description and all UI strings resolve against this bundle;
       English is the fallback, Chinese (_zh) is used when the IDE runs in Chinese. -->
  <resource-bundle>messages.ClaudeCommitBundle</resource-bundle>
  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.vcs</depends>
  <!-- Optional: "发送 CC 引用" needs the Terminal plugin (bundled, but users can disable
       it). Everything else must keep working without it. -->
  <depends optional="true" config-file="claude-commit-terminal.xml">org.jetbrains.plugins.terminal</depends>

  <extensions defaultExtensionNs="com.intellij">
    <applicationConfigurable parentId="tools"
                             id="com.github.claudecommit.settings"
                             displayName="Claude Code Commit"
                             instance="com.github.claudecommit.ClaudeCommitConfigurable"/>
    <notificationGroup id="Claude Code Commit" displayType="BALLOON"/>
  </extensions>

  <actions>
    <!-- text/description come from the resource bundle (action.<id>.text / .description). -->
    <action id="ClaudeCommit.Generate"
            class="com.github.claudecommit.ClaudeCommitAction"
            icon="AllIcons.Actions.Lightning">
      <add-to-group group-id="Vcs.MessageActionGroup"/>
    </action>
    <!-- CC 引用 actions sit at the top of the editor popup, and at the bottom of the
         project view popup. The leading separator divides them from the items above
         in the project view; in the editor popup it sits at the very top and the
         platform trims it. The trailing separator does the reverse. "发送 CC 引用"
         joins this group from claude-commit-terminal.xml when the Terminal plugin is enabled. -->
    <group id="ClaudeCommit.CcReferenceGroup">
      <add-to-group group-id="EditorPopupMenu" anchor="first"/>
      <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
      <separator/>
      <action id="ClaudeCommit.CopyCcReference"
              class="com.github.claudecommit.CopyCcReferenceAction"
              icon="/icons/claude.svg"/>
      <separator/>
    </group>
  </actions>
</idea-plugin>
