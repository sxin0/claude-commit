<!-- Loaded only when the (optional) org.jetbrains.plugins.terminal dependency is
     enabled — see the <depends optional="true"> entry in plugin.xml. -->
<idea-plugin>
  <actions>
    <action id="ClaudeCommit.SendCcReference"
            class="com.github.claudecommit.SendCcReferenceAction"
            text="发送 CC 引用"
            description="Type a Claude Code reference (@path#Lstart-end) into the active terminal tab"
            icon="/icons/claude.svg">
      <add-to-group group-id="ClaudeCommit.CcReferenceGroup" anchor="after"
                    relative-to-action="ClaudeCommit.CopyCcReference"/>
      <!-- Cmd+Option+K on Mac, Ctrl+Alt+K elsewhere ("Mac OS X 10.5+" is the
           internal id of the macOS keymap, which otherwise inherits $default).
           replace-all drops the inherited ctrl alt K so the Mac keymap only
           binds meta alt K. -->
      <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt K"/>
      <keyboard-shortcut keymap="Mac OS X 10.5+" first-keystroke="meta alt K" replace-all="true"/>
    </action>
  </actions>
</idea-plugin>
